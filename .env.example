# ─────────────────────────────────────────────
# Database (Neon Postgres recommended)
# ─────────────────────────────────────────────
# Get your connection string from: https://neon.tech
# Create a project → copy the connection string → paste below
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/kartigo?sslmode=require&connect_timeout=30

# Also set this if you use Neon's serverless driver separately
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/kartigo?sslmode=require&connect_timeout=30

# ─────────────────────────────────────────────
# Auth / Session
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-strong-random-secret

# Base URL of your deployed app (no trailing slash)
APP_URL=https://your-repl-name.replit.app

# If running behind Replit Auth / OpenID Connect
ISSUER_URL=https://replit.com/oidc

# ─────────────────────────────────────────────
# Cloudinary (image uploads)
# ─────────────────────────────────────────────
# Sign up at: https://cloudinary.com
# Dashboard → API Keys → copy values below
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Same value as CLOUDINARY_CLOUD_NAME — exposed to the browser
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─────────────────────────────────────────────
# Razorpay (payments)
# ─────────────────────────────────────────────
# Sign up at: https://razorpay.com
# Settings → API Keys → Generate test key pair
# Use rzp_test_* for development, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# Webhooks → Add endpoint → copy the webhook signing secret
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Resend (transactional email)
# ─────────────────────────────────────────────
# Sign up at: https://resend.com → API Keys → Create Key
RESEND_API_KEY=
# Must be a verified sending domain. Use onboarding@resend.dev for testing.
EMAIL_FROM=noreply@kartigo.com

# ─────────────────────────────────────────────
# Analytics (optional)
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Options: trace | debug | info | warn | error
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Node environment
# ─────────────────────────────────────────────
NODE_ENV=production
